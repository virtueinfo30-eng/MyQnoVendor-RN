+        view.setShowFrame(enabled)
+    }
+
+    @ReactProp(name = "laserColor", defaultInt = Color.RED)
+    override fun setLaserColor(view: CKCamera, @ColorInt color: Int?) {
+        view.setLaserColor(color ?: Color.RED)
+    }
